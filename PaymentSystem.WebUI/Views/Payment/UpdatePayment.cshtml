@model dynamic
@{
    ViewData["Title"] = "Update Payment";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-edit"></i> Update Payment</h1><p>Edit payment</p></div><a asp-controller="Payment" asp-action="GetAllPayments" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="Payment" asp-action="UpdatePayment" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model?.Id" />
        <div class="form-group"><label for="Amount">Amount</label><input type="number" id="Amount" name="Amount" class="form-control" value="@Model?.Amount" step="0.01" required /></div>
        <div class="form-group"><label for="MaskedCardNumber">Card Number</label><input type="text" id="MaskedCardNumber" name="MaskedCardNumber" class="form-control" value="@Model?.MaskedCardNumber" /></div>
        <div class="form-group"><label for="Description">Description</label><textarea id="Description" name="Description" class="form-control" rows="3">@Model?.Description</textarea></div>
        <div class="form-group"><label for="UserId">User ID</label><input type="text" id="UserId" name="UserId" class="form-control" value="@Model?.UserId" required /></div>
        <div class="form-group"><label for="MerchantId">Merchant ID</label><input type="number" id="MerchantId" name="MerchantId" class="form-control" value="@Model?.MerchantId" required /></div>
        <div class="form-group"><label for="CurrencyId">Currency ID</label><input type="number" id="CurrencyId" name="CurrencyId" class="form-control" value="@Model?.CurrencyId" required /></div>
        <div class="form-group"><label for="PaymentStatusId">Payment Status ID</label><input type="number" id="PaymentStatusId" name="PaymentStatusId" class="form-control" value="@Model?.PaymentStatusId" required /></div>
        <div class="form-actions"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update</button><a asp-controller="Payment" asp-action="GetAllPayments" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a></div>
    </form>
</div></div>
