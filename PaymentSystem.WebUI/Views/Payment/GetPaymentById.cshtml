@model dynamic
@{
    ViewData["Title"] = "Payment Detail";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-file-alt"></i> Payment Detail</h1><p>ID: <strong>@Model?.Id</strong></p></div><a asp-controller="Payment" asp-action="GetAllPayments" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
@if (Model == null) { <div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i><strong>Not found!</strong></div> }
else {
    <div class="card mb-3"><div class="card-header"><h3><i class="fas fa-money-bill-wave"></i> Payment Information</h3></div><div class="card-body"><div class="detail-grid">
        <div class="detail-row"><div class="detail-label">ID:</div><div class="detail-value">@Model.Id</div></div>
        <div class="detail-row"><div class="detail-label">Amount:</div><div class="detail-value"><strong>$@Model.Amount</strong></div></div>
        <div class="detail-row"><div class="detail-label">Card Number:</div><div class="detail-value"><code>@Model.MaskedCardNumber</code></div></div>
        <div class="detail-row"><div class="detail-label">Description:</div><div class="detail-value">@Model.Description</div></div>
        <div class="detail-row"><div class="detail-label">Idempotency Key:</div><div class="detail-value"><code>@Model.IdempotencyKey</code></div></div>
    </div></div></div>
    <div class="card mb-3"><div class="card-header"><h3><i class="fas fa-user"></i> Related Information</h3></div><div class="card-body"><div class="detail-grid">
        <div class="detail-row"><div class="detail-label">User:</div><div class="detail-value">@Model.UserEmail</div></div>
        <div class="detail-row"><div class="detail-label">Merchant:</div><div class="detail-value">@Model.MerchantName</div></div>
        <div class="detail-row"><div class="detail-label">Currency:</div><div class="detail-value">@Model.CurrencyName</div></div>
        <div class="detail-row"><div class="detail-label">Payment Status:</div><div class="detail-value">@Model.PaymentStatusName</div></div>
    </div></div></div>
    <div class="card mb-3"><div class="card-header"><h3><i class="fas fa-toggle-on"></i> Status</h3></div><div class="card-body"><div class="detail-grid">
        <div class="detail-row"><div class="detail-label">Active:</div><div class="detail-value">@(Model.IsActive == true ? "<span class='status-badge status-active'>Active</span>" : "<span class='status-badge status-inactive'>Inactive</span>")</div></div>
        <div class="detail-row"><div class="detail-label">Deleted:</div><div class="detail-value">@(Model.IsDeleted == true ? "<span class='status-badge status-deleted'>Deleted</span>" : "No")</div></div>
        <div class="detail-row"><div class="detail-label">Created:</div><div class="detail-value">@Model.CreatedDate?.ToString("dd MMM yyyy, HH:mm:ss")</div></div>
        <div class="detail-row"><div class="detail-label">Updated:</div><div class="detail-value">@(Model.UpdatedDate?.ToString("dd MMM yyyy, HH:mm:ss") ?? "Never")</div></div>
    </div></div></div>
    <div class="card"><div class="card-header"><h3><i class="fas fa-cogs"></i> Actions</h3></div><div class="card-body"><div class="action-buttons">
        <a asp-controller="Payment" asp-action="GetPaymentForEdit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="fas fa-edit"></i> Edit</a>
        @if (Model.IsActive == false) { <form asp-controller="Payment" asp-action="SetActive" asp-route-id="@Model.Id" method="post" class="inline-form"><button type="submit" class="btn btn-success" onclick="return confirm('Set active?')"><i class="fas fa-check"></i> Set Active</button></form> }
        else { <form asp-controller="Payment" asp-action="SetInactive" asp-route-id="@Model.Id" method="post" class="inline-form"><button type="submit" class="btn btn-warning" onclick="return confirm('Set inactive?')"><i class="fas fa-ban"></i> Set Inactive</button></form> }
        @if (Model.IsDeleted == false) { <form asp-controller="Payment" asp-action="SoftDelete" asp-route-id="@Model.Id" method="post" class="inline-form"><button type="submit" class="btn btn-danger" onclick="return confirm('Soft delete?')"><i class="fas fa-trash"></i> Soft Delete</button></form> }
        else { <form asp-controller="Payment" asp-action="Restore" asp-route-id="@Model.Id" method="post" class="inline-form"><button type="submit" class="btn btn-primary" onclick="return confirm('Restore?')"><i class="fas fa-undo"></i> Restore</button></form> }
        <form asp-controller="Payment" asp-action="DeletePayment" asp-route-id="@Model.Id" method="post" class="inline-form"><button type="submit" class="btn btn-dark" onclick="return confirm('PERMANENTLY delete?')"><i class="fas fa-exclamation-triangle"></i> Hard Delete</button></form>
    </div></div></div>
}
