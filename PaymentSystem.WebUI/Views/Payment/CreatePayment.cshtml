@model dynamic
@{
    ViewData["Title"] = "Create Payment";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-plus-circle"></i> Create Payment</h1><p>Add a new payment</p></div><a asp-controller="Payment" asp-action="GetAllPayments" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="Payment" asp-action="CreatePayment" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group"><label for="Amount">Amount</label><input type="number" id="Amount" name="Amount" class="form-control" placeholder="e.g., 100.00" step="0.01" required /></div>
        <div class="form-group"><label for="MaskedCardNumber">Card Number</label><input type="text" id="MaskedCardNumber" name="MaskedCardNumber" class="form-control" placeholder="e.g., ****1234" /></div>
        <div class="form-group"><label for="Description">Description</label><textarea id="Description" name="Description" class="form-control" placeholder="Payment description" rows="3"></textarea></div>
        <div class="form-group"><label for="UserId">User ID</label><input type="text" id="UserId" name="UserId" class="form-control" placeholder="User GUID" required /></div>
        <div class="form-group"><label for="MerchantId">Merchant ID</label><input type="number" id="MerchantId" name="MerchantId" class="form-control" placeholder="Merchant ID" required /></div>
        <div class="form-group"><label for="CurrencyId">Currency ID</label><input type="number" id="CurrencyId" name="CurrencyId" class="form-control" placeholder="Currency ID" required /></div>
        <div class="form-group"><label for="PaymentStatusId">Payment Status ID</label><input type="number" id="PaymentStatusId" name="PaymentStatusId" class="form-control" placeholder="Status ID" required /></div>
        <div class="form-actions"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create</button><a asp-controller="Payment" asp-action="GetAllPayments" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a></div>
    </form>
</div></div>
