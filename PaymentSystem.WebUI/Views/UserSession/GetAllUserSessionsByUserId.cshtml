@model List<dynamic>
@{
    ViewData["Title"] = "User Sessions By User";
    Layout = "_AdminLayout";
    var userId = ViewBag.UserId as string;
}
<div class="user-session-list-page">
    <div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-user"></i> User Sessions By User</h1><p>User ID: <code>@userId</code></p></div><div><a asp-controller="UserSession" asp-action="GetAllUserSessions" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to All</a></div></div></div>
    <div class="filter-links mb-3">
        <a asp-controller="UserSession" asp-action="GetAllUserSessions" class="btn btn-outline-secondary"><i class="fas fa-list"></i> All</a>
        <a asp-controller="UserSession" asp-action="GetAllOnlineUserSessions" class="btn btn-outline-secondary"><i class="fas fa-wifi"></i> Online</a>
        <a asp-controller="UserSession" asp-action="GetAllUserSessionsByUserId" class="btn btn-primary active-filter"><i class="fas fa-user"></i> By User</a>
        <a asp-controller="UserSession" asp-action="GetAllUserSessionsByLoginDate" class="btn btn-outline-secondary"><i class="fas fa-calendar"></i> By Login Date</a>
        <a asp-controller="UserSession" asp-action="GetAllUserSessionsByOnlineDuration" class="btn btn-outline-secondary"><i class="fas fa-hourglass-half"></i> By Duration</a>
        <a asp-controller="UserSession" asp-action="GetAllUserSessionsForAdmin" class="btn btn-outline-secondary"><i class="fas fa-shield-alt"></i> All (Admin)</a>
    </div>
    <div class="card"><div class="card-body">
        @if (Model == null || Model.Count == 0) { <div class="empty-state"><i class="fas fa-inbox"></i><p>No sessions found for this user</p></div> }
        else {
            <div class="alert alert-info mb-3"><i class="fas fa-info-circle"></i><strong>@Model.Count</strong> session(s) found for this user</div>
            <div class="table-responsive">
                <table class="data-table" id="user-session-table">
                    <thead><tr><th>#</th><th>Login Time</th><th>Logout Time</th><th>Duration (min)</th><th>IP Address</th><th>Status</th><th>Actions</th></tr></thead>
                    <thead><tr><th></th><th></th><th></th><th></th><th><input type="text" class="column-search" placeholder="Search IP..." /></th><th><select class="column-search"><option value="">All</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></th><th></th></tr></thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var session in Model) {
                            <tr><td>@i</td><td>@session.LoginDate?.ToString("dd MMM yyyy HH:mm")</td><td>@(session.LogoutDate?.ToString("dd MMM yyyy HH:mm") ?? "Online")</td><td>@session.OnlineDurationTime</td><td><code>@session.IpAddress</code></td><td>@(session.IsActive == true ? "<span class='status-badge status-active'>Active</span>" : "<span class='status-badge status-inactive'>Inactive</span>")</td>
                            <td class="actions-cell">
                                <a asp-controller="UserSession" asp-action="GetUserSessionById" asp-route-id="@session.Id" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            </td></tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div></div>
</div>
@section Scripts {
    <script>
        $(document).ready(function() {
            var t = $('#user-session-table').DataTable({"language": {"url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json"}, "pageLength": 50, "lengthMenu": [[25,50,100,250,-1],[25,50,100,250,"All"]], "order":[[1,'desc']], "columnDefs":[{"orderable":false,"targets":[6]}], "dom": '<"top"lf>rt<"bottom"ip><"clear">'});
            t.columns().every(function(){var th=this;if([4,5].includes(this.index())){$('.column-search').eq(this.index()).on('keyup change',function(){if(th.search()!==this.value){th.search(this.value,false,true).draw();}});}});
        });
    </script>
}
