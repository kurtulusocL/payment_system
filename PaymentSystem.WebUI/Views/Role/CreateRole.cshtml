@model dynamic
@{
    ViewData["Title"] = "Create Role";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-plus-circle"></i> Create Role</h1><p>Add a new role</p></div><a asp-controller="Role" asp-action="GetAllRoles" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="Role" asp-action="CreateRole" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group"><label for="Name">Name</label><input type="text" id="Name" name="Name" class="form-control" placeholder="e.g., Admin" required /></div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create</button>
            <a asp-controller="Role" asp-action="GetAllRoles" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div></div>
