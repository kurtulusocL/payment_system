@model List<dynamic>
@{
    ViewData["Title"] = "Currencies";
    Layout = "_AdminLayout";
}

<div class="currency-list-page">
    <div class="page-header">
        <div class="flex-between">
            <div>
                <h1><i class="fas fa-coins"></i> Currencies</h1>
                <p>Manage system currencies</p>
            </div>
            <div>
                <a asp-controller="Currency" asp-action="CreateCurrency" class="btn btn-primary">
                    <i class="fas fa-plus"></i> New Currency
                </a>
            </div>
        </div>
    </div>

    <div class="filter-links mb-3">
        <a asp-controller="Currency" asp-action="GetAllCurrencies" class="btn btn-primary active-filter">
            <i class="fas fa-coins"></i> Active
        </a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByPayment" class="btn btn-outline-secondary">
            <i class="fas fa-credit-card"></i> By Payments
        </a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByWallet" class="btn btn-outline-secondary">
            <i class="fas fa-wallet"></i> By Wallets
        </a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByTransaction" class="btn btn-outline-secondary">
            <i class="fas fa-exchange-alt"></i> By Transactions
        </a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesForAdmin" class="btn btn-outline-secondary">
            <i class="fas fa-list"></i> All (Admin)
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            @if (Model == null || Model.Count == 0)
            {
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>No currencies found</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="data-table" id="currency-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Code</th>
                                <th>Symbol</th>
                                <th>Payments</th>
                                <th>Wallets</th>
                                <th>Transactions</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <thead>
                            <tr>
                                <th></th>
                                <th><input type="text" class="column-search" placeholder="Search name..." /></th>
                                <th><input type="text" class="column-search" placeholder="Search code..." /></th>
                                <th><input type="text" class="column-search" placeholder="Search symbol..." /></th>
                                <th></th>
                                <th></th>
                                <th></th>
                                <th><select class="column-search">
                                    <option value="">All</option>
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                </select></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int i = 1; }
                            @foreach (var currency in Model)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td><strong>@currency.Name</strong></td>
                                    <td><code>@currency.Code</code></td>
                                    <td>@currency.Symbol</td>
                                    <td>@currency.PaymentCount</td>
                                    <td>@currency.WalletCount</td>
                                    <td>@currency.TransactionCount</td>
                                    <td>
                                        @if (currency.IsActive == true)
                                        {
                                            <span class="status-badge status-active">Active</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td class="actions-cell">
                                        <a asp-controller="Currency" asp-action="GetCurrencyById" asp-route-id="@currency.Id" class="btn btn-sm btn-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-controller="Currency" asp-action="GetCurrencyForEdit" asp-route-id="@currency.Id" class="btn btn-sm btn-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (currency.IsActive == false)
                                        {
                                            <form asp-controller="Currency" asp-action="SetActive" asp-route-id="@currency.Id" method="post" class="inline-form">
                                                <button type="submit" class="btn btn-sm btn-success" title="Set Active" onclick="return confirm('Set active?')">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-controller="Currency" asp-action="SetInactive" asp-route-id="@currency.Id" method="post" class="inline-form">
                                                <button type="submit" class="btn btn-sm btn-warning" title="Set Inactive" onclick="return confirm('Set inactive?')">
                                                    <i class="fas fa-ban"></i>
                                                </button>
                                            </form>
                                        }
                                        @if (currency.IsDeleted == false)
                                        {
                                            <form asp-controller="Currency" asp-action="SoftDelete" asp-route-id="@currency.Id" method="post" class="inline-form">
                                                <button type="submit" class="btn btn-sm btn-danger" title="Soft Delete" onclick="return confirm('Soft delete?')">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-controller="Currency" asp-action="Restore" asp-route-id="@currency.Id" method="post" class="inline-form">
                                                <button type="submit" class="btn btn-sm btn-primary" title="Restore" onclick="return confirm('Restore?')">
                                                    <i class="fas fa-undo"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#currency-table').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json" },
                "pageLength": 50,
                "lengthMenu": [[25, 50, 100, 250, -1], [25, 50, 100, 250, "All"]],
                "order": [[1, 'asc']],
                "columnDefs": [{ "orderable": false, "targets": [8] }],
                "dom": '<"top"lf>rt<"bottom"ip><"clear">'
            });

            table.columns().every(function() {
                var that = this;
                if ([1, 2, 3, 7].includes(this.index())) {
                    $('.column-search').eq(this.index()).on('keyup change', function() {
                        if (that.search() !== this.value) {
                            that.search(this.value, false, true).draw();
                        }
                    });
                }
            });
        });
    </script>
}
