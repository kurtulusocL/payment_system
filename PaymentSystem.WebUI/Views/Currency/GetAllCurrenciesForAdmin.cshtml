@model List<dynamic>
@{
    ViewData["Title"] = "All Currencies (Admin)";
    Layout = "_AdminLayout";
}

<div class="currency-admin-page">
    <div class="page-header">
        <div class="flex-between">
            <div><h1><i class="fas fa-shield-alt"></i> All Currencies (Admin View)</h1><p>Complete list with all records (active, inactive, deleted)</p></div>
            <div>
                <a asp-controller="Currency" asp-action="CreateCurrency" class="btn btn-primary"><i class="fas fa-plus"></i> New Currency</a>
            </div>
        </div>
    </div>

    <div class="filter-links mb-3">
        <a asp-controller="Currency" asp-action="GetAllCurrencies" class="btn btn-outline-secondary"><i class="fas fa-coins"></i> Active</a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByPayment" class="btn btn-outline-secondary"><i class="fas fa-credit-card"></i> By Payments</a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByWallet" class="btn btn-outline-secondary"><i class="fas fa-wallet"></i> By Wallets</a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByTransaction" class="btn btn-outline-secondary"><i class="fas fa-exchange-alt"></i> By Transactions</a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesForAdmin" class="btn btn-primary active-filter"><i class="fas fa-list"></i> All (Admin)</a>
    </div>

    <div class="bulk-actions-bar card mb-3">
        <div class="card-body">
            <div class="flex-between">
                <div class="bulk-actions-left">
                    <label class="checkbox-label"><input type="checkbox" id="selectAllCheckbox" onclick="toggleSelectAll()" /><span class="checkmark"></span>Select All</label>
                    <span id="selectedCount" class="selected-count">0 items selected</span>
                </div>
                <div class="bulk-actions-right">
                    <button type="button" class="btn btn-danger" id="bulkDeleteBtn" onclick="bulkDelete()" disabled><i class="fas fa-trash-alt"></i> Delete Selected</button>
                </div>
            </div>
        </div>
    </div>
    <form id="bulkDeleteForm" asp-controller="Currency" asp-action="DeleteCurrenciesById" method="post" style="display:none;"></form>

    <div class="card">
        <div class="card-body">
            @if (Model == null || Model.Count == 0)
            {
                <div class="empty-state"><i class="fas fa-inbox"></i><p>No currencies found</p></div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="data-table" id="currency-table">
                        <thead>
                            <tr><th><input type="checkbox" id="headerCheckbox" onclick="toggleSelectAll()" /></th><th>#</th><th>Name</th><th>Code</th><th>Symbol</th><th>Payments</th><th>Wallets</th><th>Transactions</th><th>Active</th><th>Deleted</th><th>Actions</th></tr>
                        </thead>
                        <thead>
                            <tr>
                                <th></th><th></th>
                                <th><input type="text" class="column-search" placeholder="Search name..." /></th>
                                <th><input type="text" class="column-search" placeholder="Search code..." /></th>
                                <th><input type="text" class="column-search" placeholder="Search symbol..." /></th>
                                <th></th><th></th><th></th>
                                <th><select class="column-search"><option value="">All</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></th>
                                <th><select class="column-search"><option value="">All</option><option value="Deleted">Deleted</option><option value="Not Deleted">Not Deleted</option></select></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int i = 1; }
                            @foreach (var currency in Model)
                            {
                                <tr class="@(currency.IsDeleted == true ? "row-deleted" : "")">
                                    <td><input type="checkbox" class="row-checkbox" data-id="@currency.Id" onclick="updateSelectedCount()" /></td>
                                    <td>@i</td>
                                    <td><strong>@currency.Name</strong></td>
                                    <td><code>@currency.Code</code></td>
                                    <td>@currency.Symbol</td>
                                    <td>@currency.PaymentCount</td>
                                    <td>@currency.WalletCount</td>
                                    <td>@currency.TransactionCount</td>
                                    <td>@(currency.IsActive == true ? "<span class='status-badge status-active'>Active</span>" : "<span class='status-badge status-inactive'>Inactive</span>")</td>
                                    <td>@(currency.IsDeleted == true ? "<span class='status-badge status-deleted'>Deleted</span>" : "<span class='status-badge status-active'>Not Deleted</span>")</td>
                                    <td class="actions-cell">
                                        <a asp-controller="Currency" asp-action="GetCurrencyById" asp-route-id="@currency.Id" class="btn btn-sm btn-info" title="Details"><i class="fas fa-eye"></i></a>
                                        <a asp-controller="Currency" asp-action="GetCurrencyForEdit" asp-route-id="@currency.Id" class="btn btn-sm btn-warning" title="Edit"><i class="fas fa-edit"></i></a>
                                        @if (currency.IsActive == false)
                                        { <form asp-controller="Currency" asp-action="SetActive" asp-route-id="@currency.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Set active?')"><i class="fas fa-check"></i></button></form> }
                                        else
                                        { <form asp-controller="Currency" asp-action="SetInactive" asp-route-id="@currency.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Set inactive?')"><i class="fas fa-ban"></i></button></form> }
                                        @if (currency.IsDeleted == false)
                                        { <form asp-controller="Currency" asp-action="SoftDelete" asp-route-id="@currency.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Soft delete?')"><i class="fas fa-trash"></i></button></form> }
                                        else
                                        { <form asp-controller="Currency" asp-action="Restore" asp-route-id="@currency.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-primary" onclick="return confirm('Restore?')"><i class="fas fa-undo"></i></button></form> }
                                        <form asp-controller="Currency" asp-action="DeleteCurrency" asp-route-id="@currency.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-dark" title="Hard Delete" onclick="return confirm('PERMANENTLY delete?')"><i class="fas fa-exclamation-triangle"></i></button></form>
                                    </td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#currency-table').DataTable({
                "language": { "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json" },
                "pageLength": 50, "lengthMenu": [[25, 50, 100, 250, -1], [25, 50, 100, 250, "All"]],
                "order": [[2, 'asc']], "columnDefs": [{ "orderable": false, "targets": [0, 10] }],
                "dom": '<"top"lf>rt<"bottom"ip><"clear">'
            });
            table.columns().every(function() {
                var that = this;
                if ([2, 3, 4, 8, 9].includes(this.index())) {
                    $('.column-search').eq(this.index()).on('keyup change', function() {
                        if (that.search() !== this.value) { that.search(this.value, false, true).draw(); }
                    });
                }
            });
            $('#currency-table').on('change', '.row-checkbox', function() { updateSelectedCount(); });
            $('#selectAllCheckbox').on('change', function() {
                var isChecked = $(this).is(':checked');
                $('#currency-table').find('.row-checkbox').prop('checked', isChecked);
                $('#headerCheckbox').prop('checked', isChecked);
                updateSelectedCount();
            });
        });

        function toggleSelectAll() {
            var isChecked = document.getElementById('headerCheckbox').checked || document.getElementById('selectAllCheckbox').checked;
            document.getElementById('headerCheckbox').checked = isChecked;
            document.getElementById('selectAllCheckbox').checked = isChecked;
            document.querySelectorAll('.row-checkbox').forEach(cb => { cb.checked = isChecked; });
            updateSelectedCount();
        }
        function updateSelectedCount() {
            var selected = Array.from(document.querySelectorAll('.row-checkbox')).filter(cb => cb.checked).length;
            document.getElementById('selectedCount').textContent = selected + ' item(s) selected';
            document.getElementById('bulkDeleteBtn').disabled = selected === 0;
            var total = document.querySelectorAll('.row-checkbox').length;
            document.getElementById('headerCheckbox').checked = selected === total;
            document.getElementById('selectAllCheckbox').checked = selected === total;
        }
        function bulkDelete() {
            var ids = Array.from(document.querySelectorAll('.row-checkbox:checked')).map(cb => cb.dataset.id);
            if (ids.length === 0) { alert('No items selected'); return; }
            if (!confirm('PERMANENTLY delete ' + ids.length + ' currencies? This cannot be undone!')) return;
            var form = document.getElementById('bulkDeleteForm');
            form.querySelectorAll('input[name="ids"]').forEach(i => i.remove());
            ids.forEach(id => { var i = document.createElement('input'); i.type='hidden'; i.name='ids'; i.value=id; form.appendChild(i); });
            form.submit();
        }
    </script>
}
