@model dynamic
@{
    ViewData["Title"] = "Currency Detail";
    Layout = "_AdminLayout";
}

<div class="currency-detail-page">
    <div class="page-header">
        <div class="flex-between">
            <div>
                <h1><i class="fas fa-file-alt"></i> Currency Detail</h1>
                <p>Detailed information for currency ID: <strong>@Model?.Id</strong></p>
            </div>
            <div>
                <a asp-controller="Currency" asp-action="GetAllCurrencies" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>

    @if (Model == null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-triangle"></i>
            <strong>Currency not found!</strong>
        </div>
    }
    else
    {
        <div class="card mb-3">
            <div class="card-header"><h3><i class="fas fa-info-circle"></i> General Information</h3></div>
            <div class="card-body">
                <div class="detail-grid">
                    <div class="detail-row"><div class="detail-label">ID:</div><div class="detail-value">@Model.Id</div></div>
                    <div class="detail-row"><div class="detail-label">Name:</div><div class="detail-value"><strong>@Model.Name</strong></div></div>
                    <div class="detail-row"><div class="detail-label">Code:</div><div class="detail-value"><code>@Model.Code</code></div></div>
                    <div class="detail-row"><div class="detail-label">Symbol:</div><div class="detail-value">@Model.Symbol</div></div>
                    <div class="detail-row"><div class="detail-label">Description:</div><div class="detail-value">@Model.Description</div></div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><h3><i class="fas fa-chart-bar"></i> Statistics</h3></div>
            <div class="card-body">
                <div class="detail-grid">
                    <div class="detail-row"><div class="detail-label">Payment Count:</div><div class="detail-value">@Model.PaymentCount</div></div>
                    <div class="detail-row"><div class="detail-label">Wallet Count:</div><div class="detail-value">@Model.WalletCount</div></div>
                    <div class="detail-row"><div class="detail-label">Transaction Count:</div><div class="detail-value">@Model.TransactionCount</div></div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><h3><i class="fas fa-toggle-on"></i> Status</h3></div>
            <div class="card-body">
                <div class="detail-grid">
                    <div class="detail-row"><div class="detail-label">Active Status:</div><div class="detail-value">@(Model.IsActive == true ? "<span class='status-badge status-active'>Active</span>" : "<span class='status-badge status-inactive'>Inactive</span>")</div></div>
                    <div class="detail-row"><div class="detail-label">Deleted Status:</div><div class="detail-value">@(Model.IsDeleted == true ? "<span class='status-badge status-deleted'>Deleted</span>" : "<span class='status-badge status-active'>Not Deleted</span>")</div></div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><h3><i class="fas fa-clock"></i> Timestamps</h3></div>
            <div class="card-body">
                <div class="detail-grid">
                    <div class="detail-row"><div class="detail-label">Created Date:</div><div class="detail-value">@Model.CreatedDate?.ToString("dd MMMM yyyy, HH:mm:ss")</div></div>
                    <div class="detail-row"><div class="detail-label">Updated Date:</div><div class="detail-value">@(Model.UpdatedDate?.ToString("dd MMMM yyyy, HH:mm:ss") ?? "Never")</div></div>
                    <div class="detail-row"><div class="detail-label">Deleted Date:</div><div class="detail-value">@(Model.DeletedDate?.ToString("dd MMMM yyyy, HH:mm:ss") ?? "Not Deleted")</div></div>
                    <div class="detail-row"><div class="detail-label">Suspended Date:</div><div class="detail-value">@(Model.SuspendedDate?.ToString("dd MMMM yyyy, HH:mm:ss") ?? "Not Suspended")</div></div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><h3><i class="fas fa-cogs"></i> Actions</h3></div>
            <div class="card-body">
                <div class="action-buttons">
                    <a asp-controller="Currency" asp-action="GetCurrencyForEdit" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="fas fa-edit"></i> Edit Currency
                    </a>
                    @if (Model.IsActive == false)
                    {
                        <form asp-controller="Currency" asp-action="SetActive" asp-route-id="@Model.Id" method="post" class="inline-form">
                            <button type="submit" class="btn btn-success" onclick="return confirm('Set active?')"><i class="fas fa-check"></i> Set Active</button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Currency" asp-action="SetInactive" asp-route-id="@Model.Id" method="post" class="inline-form">
                            <button type="submit" class="btn btn-warning" onclick="return confirm('Set inactive?')"><i class="fas fa-ban"></i> Set Inactive</button>
                        </form>
                    }
                    @if (Model.IsDeleted == false)
                    {
                        <form asp-controller="Currency" asp-action="SoftDelete" asp-route-id="@Model.Id" method="post" class="inline-form">
                            <button type="submit" class="btn btn-danger" onclick="return confirm('Soft delete?')"><i class="fas fa-trash"></i> Soft Delete</button>
                        </form>
                    }
                    else
                    {
                        <form asp-controller="Currency" asp-action="Restore" asp-route-id="@Model.Id" method="post" class="inline-form">
                            <button type="submit" class="btn btn-primary" onclick="return confirm('Restore?')"><i class="fas fa-undo"></i> Restore</button>
                        </form>
                    }
                    <form asp-controller="Currency" asp-action="DeleteCurrency" asp-route-id="@Model.Id" method="post" class="inline-form">
                        <button type="submit" class="btn btn-dark" onclick="return confirm('PERMANENTLY delete?')"><i class="fas fa-exclamation-triangle"></i> Hard Delete</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
