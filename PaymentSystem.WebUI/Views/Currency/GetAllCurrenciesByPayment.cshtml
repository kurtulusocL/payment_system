@model List<dynamic>
@{
    ViewData["Title"] = "Currencies By Payments";
    Layout = "_AdminLayout";
}
<div class="currency-list-page">
    <div class="page-header"><div><h1><i class="fas fa-credit-card"></i> Currencies By Payments</h1><p>Currencies ordered by payment count</p></div><div><a asp-controller="Currency" asp-action="CreateCurrency" class="btn btn-primary"><i class="fas fa-plus"></i> New Currency</a></div></div>
    <div class="filter-links mb-3">
        <a asp-controller="Currency" asp-action="GetAllCurrencies" class="btn btn-outline-secondary"><i class="fas fa-coins"></i> Active</a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByPayment" class="btn btn-primary active-filter"><i class="fas fa-credit-card"></i> By Payments</a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByWallet" class="btn btn-outline-secondary"><i class="fas fa-wallet"></i> By Wallets</a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesByTransaction" class="btn btn-outline-secondary"><i class="fas fa-exchange-alt"></i> By Transactions</a>
        <a asp-controller="Currency" asp-action="GetAllCurrenciesForAdmin" class="btn btn-outline-secondary"><i class="fas fa-list"></i> All (Admin)</a>
    </div>
    <div class="card"><div class="card-body">
        @if (Model == null || Model.Count == 0) { <div class="empty-state"><i class="fas fa-inbox"></i><p>No currencies found</p></div> }
        else {
            <div class="table-responsive">
                <table class="data-table" id="currency-table">
                    <thead><tr><th>#</th><th>Name</th><th>Code</th><th>Symbol</th><th>Payments</th><th>Wallets</th><th>Transactions</th><th>Status</th><th>Actions</th></tr></thead>
                    <thead><tr><th></th><th><input type="text" class="column-search" placeholder="Search name..." /></th><th><input type="text" class="column-search" placeholder="Search code..." /></th><th><input type="text" class="column-search" placeholder="Search symbol..." /></th><th></th><th></th><th></th><th><select class="column-search"><option value="">All</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></th><th></th></tr></thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var c in Model) {
                            <tr><td>@i</td><td><strong>@c.Name</strong></td><td><code>@c.Code</code></td><td>@c.Symbol</td><td>@c.PaymentCount</td><td>@c.WalletCount</td><td>@c.TransactionCount</td><td>@(c.IsActive == true ? "<span class='status-badge status-active'>Active</span>" : "<span class='status-badge status-inactive'>Inactive</span>")</td>
                            <td class="actions-cell">
                                <a asp-controller="Currency" asp-action="GetCurrencyById" asp-route-id="@c.Id" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                                <a asp-controller="Currency" asp-action="GetCurrencyForEdit" asp-route-id="@c.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                @if (c.IsActive == false) { <form asp-controller="Currency" asp-action="SetActive" asp-route-id="@c.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Set active?')"><i class="fas fa-check"></i></button></form> }
                                else { <form asp-controller="Currency" asp-action="SetInactive" asp-route-id="@c.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Set inactive?')"><i class="fas fa-ban"></i></button></form> }
                                @if (c.IsDeleted == false) { <form asp-controller="Currency" asp-action="SoftDelete" asp-route-id="@c.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Soft delete?')"><i class="fas fa-trash"></i></button></form> }
                                else { <form asp-controller="Currency" asp-action="Restore" asp-route-id="@c.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-primary" onclick="return confirm('Restore?')"><i class="fas fa-undo"></i></button></form> }
                            </td></tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div></div>
</div>
@section Scripts {
    <script>
        $(document).ready(function() {
            var t = $('#currency-table').DataTable({"language": {"url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json"}, "pageLength": 50, "lengthMenu": [[25,50,100,250,-1],[25,50,100,250,"All"]], "order":[[4,'desc']], "columnDefs":[{"orderable":false,"targets":[8]}], "dom": '<"top"lf>rt<"bottom"ip><"clear">'});
            t.columns().every(function(){var th=this;if([1,2,3,7].includes(this.index())){$('.column-search').eq(this.index()).on('keyup change',function(){if(th.search()!==this.value){th.search(this.value,false,true).draw();}});}});
        });
    </script>
}
