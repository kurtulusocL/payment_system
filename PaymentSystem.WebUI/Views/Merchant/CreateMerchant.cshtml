@model dynamic
@{
    ViewData["Title"] = "Create Merchant";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-plus-circle"></i> Create Merchant</h1><p>Add a new merchant</p></div><a asp-controller="Merchant" asp-action="GetAllMerchants" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="Merchant" asp-action="CreateMerchant" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group"><label for="Name">Name</label><input type="text" id="Name" name="Name" class="form-control" placeholder="e.g., Acme Corp" required /></div>
        <div class="form-group"><label for="Email">Email</label><input type="email" id="Email" name="Email" class="form-control" placeholder="e.g., info@acme.com" required /></div>
        <div class="form-group"><label for="PhoneNumber">Phone Number</label><input type="tel" id="PhoneNumber" name="PhoneNumber" class="form-control" placeholder="e.g., +1234567890" /></div>
        <div class="form-group"><label for="TaxNumber">Tax Number</label><input type="text" id="TaxNumber" name="TaxNumber" class="form-control" placeholder="e.g., 1234567890" /></div>
        <div class="form-group"><label for="MerchantStatusId">Status</label><input type="number" id="MerchantStatusId" name="MerchantStatusId" class="form-control" placeholder="Status ID" /></div>
        <div class="form-actions"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create</button><a asp-controller="Merchant" asp-action="GetAllMerchants" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a></div>
    </form>
</div></div>
