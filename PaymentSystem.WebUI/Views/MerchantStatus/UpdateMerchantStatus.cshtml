@model dynamic
@{
    ViewData["Title"] = "Edit Merchant Status";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-edit"></i> Edit Merchant Status</h1><p>Update merchant status</p></div><a asp-controller="MerchantStatus" asp-action="GetAllMerchantStatuses" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="MerchantStatus" asp-action="UpdateMerchantStatus" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model?.Id" />
        <div class="form-group"><label for="Name">Name</label><input type="text" id="Name" name="Name" class="form-control" value="@Model?.Name" required /></div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update</button>
            <a asp-controller="MerchantStatus" asp-action="GetAllMerchantStatuses" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div></div>
