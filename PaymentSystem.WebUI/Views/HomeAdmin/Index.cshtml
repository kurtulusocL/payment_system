@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_AdminLayout";
}

<div class="admin-dashboard">
    <!-- Page Header -->
    <div class="page-header">
        <h1><i class="fas fa-tachometer-alt"></i> Admin Dashboard</h1>
        <p>System overview and statistics</p>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-grid">
        <div class="stat-card stat-card-primary">
            <div class="stat-icon">
                <i class="fas fa-users"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalUsers</h3>
                <p>Total Users</p>
                <a asp-controller="User" asp-action="GetAllUsers" class="stat-link">View Users <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="stat-card stat-card-success">
            <div class="stat-icon">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalPayments</h3>
                <p>Total Payments</p>
                <a asp-controller="Payment" asp-action="GetAllPayments" class="stat-link">View Payments <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="stat-card stat-card-warning">
            <div class="stat-icon">
                <i class="fas fa-wallet"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalWallets</h3>
                <p>Total Wallets</p>
                <a asp-controller="Wallet" asp-action="GetAllWallets" class="stat-link">View Wallets <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="stat-card stat-card-info">
            <div class="stat-icon">
                <i class="fas fa-store-alt"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalMerchants</h3>
                <p>Total Merchants</p>
                <a asp-controller="Merchant" asp-action="GetAllMerchants" class="stat-link">View Merchants <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>

        <div class="stat-card stat-card-danger">
            <div class="stat-icon">
                <i class="fas fa-bug"></i>
            </div>
            <div class="stat-content">
                <h3>@Model.TotalExceptions</h3>
                <p>Exceptions</p>
                <a asp-controller="ExceptionLogger" asp-action="GetAllExceptions" class="stat-link">View Logs <i class="fas fa-arrow-right"></i></a>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card mt-4">
        <div class="card-header">
            <i class="fas fa-bolt"></i> Quick Actions
        </div>
        <div class="card-body">
            <div class="quick-actions">
                <a asp-controller="User" asp-action="GetAllUsers" class="btn btn-primary">
                    <i class="fas fa-user-plus"></i> Manage Users
                </a>
                <a asp-controller="Role" asp-action="GetAllRoles" class="btn btn-success">
                    <i class="fas fa-user-tag"></i> Manage Roles
                </a>
                <a asp-controller="Payment" asp-action="GetAllPayments" class="btn btn-warning">
                    <i class="fas fa-credit-card"></i> View Payments
                </a>
                <a asp-controller="Audit" asp-action="GetAllAudits" class="btn btn-info">
                    <i class="fas fa-clipboard-list"></i> View Audit Logs
                </a>
                <a asp-controller="SecuritySetting" asp-action="GetAllSecuritySettings" class="btn btn-danger">
                    <i class="fas fa-cog"></i> Security Settings
                </a>
                <a asp-controller="OutboxEvent" asp-action="GetAllOutboxEvents" class="btn btn-secondary">
                    <i class="fas fa-envelope-open-text"></i> Outbox Events
                </a>
            </div>
        </div>
    </div>

    <!-- Admin Authentication Management -->
    <div class="card mt-4">
        <div class="card-header">
            <i class="fas fa-user-shield"></i> Admin Authentication
        </div>
        <div class="card-body">
            <div class="quick-actions">
                <a asp-controller="Account" asp-action="AdminRegister" class="btn btn-primary">
                    <i class="fas fa-user-plus"></i> Register Admin User
                </a>
                <a asp-controller="Account" asp-action="AdminProfile" asp-route-userId="" class="btn btn-success" id="viewUserProfileBtn">
                    <i class="fas fa-user-edit"></i> View User Profile
                </a>
                <a asp-controller="Account" asp-action="AdminChangePassword" asp-route-userId="" class="btn btn-warning" id="changeUserPasswordBtn">
                    <i class="fas fa-key"></i> Change User Password
                </a>
                <a asp-controller="User" asp-action="GetAllUsers" class="btn btn-info">
                    <i class="fas fa-list"></i> Manage User Accounts
                </a>
            </div>
            <div class="mt-3">
                <div class="input-group" style="max-width: 400px;">
                    <input type="text" class="form-control" id="adminUserIdInput" placeholder="Enter User ID for actions..." />
                    <button class="btn btn-outline-primary" type="button" onclick="goToUserProfile()">
                        <i class="fas fa-user-edit"></i> View Profile
                    </button>
                    <button class="btn btn-outline-warning" type="button" onclick="goToUserChangePassword()">
                        <i class="fas fa-key"></i> Change Password
                    </button>
                </div>
                <small class="text-muted">Enter a User ID above, then click View Profile or Change Password.</small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Initialize admin dashboard
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Admin Dashboard Loaded');
        });

        // Admin authentication navigation functions
        function goToUserProfile() {
            var userId = document.getElementById('adminUserIdInput').value.trim();
            if (!userId) {
                alert('Please enter a User ID first.');
                return;
            }
            window.location.href = '/Account/AdminProfile?userId=' + encodeURIComponent(userId);
        }

        function goToUserChangePassword() {
            var userId = document.getElementById('adminUserIdInput').value.trim();
            if (!userId) {
                alert('Please enter a User ID first.');
                return;
            }
            window.location.href = '/Account/AdminChangePassword?userId=' + encodeURIComponent(userId);
        }
    </script>
}
