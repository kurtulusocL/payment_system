@model dynamic
@{
    ViewData["Title"] = "Create Wallet";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-plus-circle"></i> Create Wallet</h1><p>Add a new wallet</p></div><a asp-controller="Wallet" asp-action="GetAllWallets" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="Wallet" asp-action="CreateWallet" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group"><label for="Balance">Balance</label><input type="number" id="Balance" name="Balance" class="form-control" placeholder="e.g., 1000.00" step="0.01" value="0" required /></div>
        <div class="form-group"><label for="UserId">User ID</label><input type="text" id="UserId" name="UserId" class="form-control" placeholder="User GUID" required /></div>
        <div class="form-group"><label for="CurrencyId">Currency ID</label><input type="number" id="CurrencyId" name="CurrencyId" class="form-control" placeholder="Currency ID" required /></div>
        <div class="form-actions"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create</button><a asp-controller="Wallet" asp-action="GetAllWallets" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a></div>
    </form>
</div></div>
