@model List<dynamic>
@{
    ViewData["Title"] = "Wallets";
    Layout = "_AdminLayout";
    var signalRHubUrl = ViewBag.SignalRHubUrl as string;
}
<div class="wallet-list-page">
    <div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-wallet"></i> Wallets</h1><p>Active wallet accounts</p></div><div><a asp-controller="Wallet" asp-action="CreateWallet" class="btn btn-primary"><i class="fas fa-plus"></i> New Wallet</a></div></div></div>
    <div class="filter-links mb-3">
        <a asp-controller="Wallet" asp-action="GetAllWallets" class="btn btn-primary active-filter"><i class="fas fa-wallet"></i> Active</a>
        <a asp-controller="Wallet" asp-action="GetAllWalletsForAdmin" class="btn btn-outline-secondary"><i class="fas fa-shield-alt"></i> All (Admin)</a>
    </div>
    <div class="card"><div class="card-body">
        @if (Model == null || Model.Count == 0) { <div class="empty-state"><i class="fas fa-inbox"></i><p>No wallets found</p></div> }
        else {
            <div class="table-responsive">
                <table class="data-table" id="wallet-table">
                    <thead><tr><th>#</th><th>User</th><th>Currency</th><th>Balance</th><th>Status</th><th>Actions</th></tr></thead>
                    <thead><tr><th></th><th><input type="text" class="column-search" placeholder="Search user..." /></th><th><input type="text" class="column-search" placeholder="Search currency..." /></th><th><input type="text" class="column-search" placeholder="Search balance..." /></th><th><select class="column-search"><option value="">All</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></th><th></th></tr></thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var w in Model) {
                            <tr data-wallet-id="@w.Id">
                                <td>@i</td><td><strong>@w.UserEmail</strong></td><td>@w.CurrencyName</td><td class="wallet-balance">$@w.Balance</td>
                                <td>@(w.IsActive == true ? "<span class='status-badge status-active'>Active</span>" : "<span class='status-badge status-inactive'>Inactive</span>")</td>
                                <td class="actions-cell">
                                    <a asp-controller="Wallet" asp-action="GetWalletById" asp-route-id="@w.Id" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                                    <a asp-controller="Wallet" asp-action="GetWalletForEdit" asp-route-id="@w.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                    @if (w.IsActive == false) { <form asp-controller="Wallet" asp-action="SetActive" asp-route-id="@w.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Set active?')"><i class="fas fa-check"></i></button></form> }
                                    else { <form asp-controller="Wallet" asp-action="SetInactive" asp-route-id="@w.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Set inactive?')"><i class="fas fa-ban"></i></button></form> }
                                    @if (w.IsDeleted == false) { <form asp-controller="Wallet" asp-action="SoftDelete" asp-route-id="@w.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Soft delete?')"><i class="fas fa-trash"></i></button></form> }
                                    else { <form asp-controller="Wallet" asp-action="Restore" asp-route-id="@w.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-primary" onclick="return confirm('Restore?')"><i class="fas fa-undo"></i></button></form> }
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div></div>
</div>
@section Scripts {
    <script>
        $(document).ready(function() {
            var t = $('#wallet-table').DataTable({"language": {"url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json"}, "pageLength": 50, "lengthMenu": [[25,50,100,250,-1],[25,50,100,250,"All"]], "order":[[3,'desc']], "columnDefs":[{"orderable":false,"targets":[5]}], "dom": '<"top"lf>rt<"bottom"ip><"clear">'});
            t.columns().every(function(){var th=this;if([1,2,3,4].includes(this.index())){$('.column-search').eq(this.index()).on('keyup change',function(){if(th.search()!==this.value){th.search(this.value,false,true).draw();}});}});
        });
        @if (!string.IsNullOrEmpty(signalRHubUrl)) {
            <text>
            const handler = new window.WalletSignalRHandler("@signalRHubUrl", {
                onBalanceChanged: function(walletId, balanceData) {
                    console.log('[SignalR] Wallet balance changed:', walletId, balanceData);
                    const row = $('#wallet-table').find(`tr[data-wallet-id="${walletId}"]`);
                    if (row.length) { row.find('.wallet-balance').text('$' + balanceData.balance.toFixed(2)).addClass('balance-updated'); setTimeout(() => row.find('.wallet-balance').removeClass('balance-updated'), 2000); }
                },
                onTransactionCompleted: function(walletId, transactionData) { showUserToast('Transaction completed for wallet ' + walletId, 'success'); },
                onWalletUpdate: function(updateData) { showUserToast(updateData.message || 'A wallet has been updated', 'info'); }
            });
            handler.initialize().then(() => {
                const ids = Array.from(document.querySelectorAll('[data-wallet-id]')).map(el => el.dataset.walletId);
                ids.forEach(id => handler.joinWalletGroup(id));
            }).catch(err => console.error('[WalletSignalR] Failed:', err));
            </text>
        }
    </script>
}
