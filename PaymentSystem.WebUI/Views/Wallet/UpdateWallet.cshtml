@model dynamic
@{
    ViewData["Title"] = "Update Wallet";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-edit"></i> Update Wallet</h1><p>Edit wallet</p></div><a asp-controller="Wallet" asp-action="GetAllWallets" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="Wallet" asp-action="UpdateWallet" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model?.Id" />
        <div class="form-group"><label for="Balance">Balance</label><input type="number" id="Balance" name="Balance" class="form-control" value="@Model?.Balance" step="0.01" required /></div>
        <div class="form-group"><label for="UserId">User ID</label><input type="text" id="UserId" name="UserId" class="form-control" value="@Model?.UserId" required /></div>
        <div class="form-group"><label for="CurrencyId">Currency ID</label><input type="number" id="CurrencyId" name="CurrencyId" class="form-control" value="@Model?.CurrencyId" required /></div>
        <div class="form-actions"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update</button><a asp-controller="Wallet" asp-action="GetAllWallets" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a></div>
    </form>
</div></div>
