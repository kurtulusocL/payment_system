@model PaymentSystem.Shared.Dtos.AuthDtos.UpdateProfileDto
@{
    ViewData["Title"] = "My Profile";
    Layout = "_Layout";
}
<div class="container py-4">
    <div class="page-header mb-4">
        <h1><i class="fas fa-user"></i> My Profile</h1>
        <p>Manage your personal information</p>
    </div>
    @if (Model == null)
    {
        <div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> Failed to load profile data.</div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header"><h3><i class="fas fa-info-circle"></i> Personal Information</h3></div>
                    <div class="card-body">
                        <form asp-controller="Account" asp-action="Profile" method="post">
                            @Html.AntiForgeryToken()
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="NameSurname" class="form-label">Full Name</label>
                                    <input type="text" asp-for="NameSurname" class="form-control" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control" value="@ViewData["Email"]" disabled />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                                    <input type="tel" asp-for="PhoneNumber" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Title" class="form-label">Title</label>
                                    <input type="text" asp-for="Title" class="form-control" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Birthdate" class="form-label">Birthdate</label>
                                    <input type="date" asp-for="Birthdate" class="form-control" value="@(Model.Birthdate != default ? Model.Birthdate.ToString("yyyy-MM-dd") : "")" />
                                </div>
                            </div>
                            <div class="mt-3">
                                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update Profile</button>
                                <a asp-controller="Account" asp-action="ChangePassword" class="btn btn-outline-secondary"><i class="fas fa-key"></i> Change Password</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card mb-4">
                    <div class="card-header"><h3><i class="fas fa-chart-bar"></i> Account Summary</h3></div>
                    <div class="card-body">
                        <div class="mb-3"><a asp-controller="UserHome" asp-action="Index" class="btn btn-sm btn-outline-primary w-100"><i class="fas fa-home"></i> Dashboard</a></div>
                        <div>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100"><i class="fas fa-sign-out-alt"></i> Logout</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
