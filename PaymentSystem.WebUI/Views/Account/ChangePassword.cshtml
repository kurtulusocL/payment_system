@model PaymentSystem.Shared.Dtos.AuthDtos.ChangePasswordDto
@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}
<div class="container py-4">
    <div class="page-header mb-4">
        <h1><i class="fas fa-key"></i> Change Password</h1>
        <p>Update your account password</p>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <form asp-controller="Account" asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label">Current Password</label>
                            <div class="password-input-wrapper">
                                <input type="password" asp-for="CurrentPassword" class="form-control" required autofocus />
                                <button type="button" class="toggle-password" onclick="togglePassword('CurrentPassword')"><i class="fas fa-eye"></i></button>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">New Password</label>
                            <div class="password-input-wrapper">
                                <input type="password" asp-for="NewPassword" class="form-control" required minlength="6" />
                                <button type="button" class="toggle-password" onclick="togglePassword('NewPassword')"><i class="fas fa-eye"></i></button>
                            </div>
                            <small class="text-muted">Minimum 6 characters</small>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ConfirmNewPassword" class="form-label">Confirm New Password</label>
                            <div class="password-input-wrapper">
                                <input type="password" asp-for="ConfirmNewPassword" class="form-control" required minlength="6" />
                                <button type="button" class="toggle-password" onclick="togglePassword('ConfirmNewPassword')"><i class="fas fa-eye"></i></button>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Change Password</button>
                            <a asp-controller="Account" asp-action="Profile" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to Profile</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/auth.js" asp-append-version="true"></script>
}
