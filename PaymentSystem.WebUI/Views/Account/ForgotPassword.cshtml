@model PaymentSystem.Shared.Dtos.AuthDtos.ForgotPasswordRequestDto
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PaymentSystem</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="auth-body">
    <div class="auth-container">
        <div class="auth-branding">
            <div class="branding-content">
                <i class="fas fa-unlock-alt"></i>
                <h1>Reset Password</h1>
                <p>We'll send you a link to reset your password</p>
                <ul class="features-list">
                    <li><i class="fas fa-envelope"></i> Link sent to email</li>
                    <li><i class="fas fa-clock"></i> Link expires in 1 hour</li>
                    <li><i class="fas fa-lock"></i> Secure password reset</li>
                </ul>
            </div>
        </div>
        <div class="auth-form-container">
            <div class="auth-form-wrapper">
                <div class="auth-header">
                    <h2>Forgot Password?</h2>
                    <p>Enter your email to receive a reset link</p>
                </div>
                @if (TempData["Error"] != null) { <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i><span>@TempData["Error"]</span></div> }
                @if (TempData["Success"] != null) { <div class="alert alert-success"><i class="fas fa-check-circle"></i><span>@TempData["Success"]</span></div> }
                <form asp-controller="Account" asp-action="ForgotPassword" method="post" class="auth-form" id="forgotPasswordForm">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label asp-for="Email"><i class="fas fa-envelope"></i> Email Address</label>
                        <input type="email" asp-for="Email" class="form-control" placeholder="Enter your email" required autofocus />
                    </div>
                    <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-paper-plane"></i> Send Reset Link</button>
                </form>
                <div class="auth-footer">
                    <p>Remember your password? <a asp-controller="Account" asp-action="Login" class="auth-link">Sign In</a></p>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/auth.js" asp-append-version="true"></script>
</body>
</html>
