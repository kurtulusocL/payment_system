@model PaymentSystem.Shared.Dtos.AuthDtos.ConfirmCodeDto
@{
    ViewData["Title"] = "Confirm Email";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PaymentSystem</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="auth-body">
    <div class="auth-container">
        <div class="auth-branding">
            <div class="branding-content">
                <i class="fas fa-envelope-open-text"></i>
                <h1>Confirm Email</h1>
                <p>Verify your email address to activate your account</p>
                <ul class="features-list">
                    <li><i class="fas fa-envelope"></i> Check your inbox</li>
                    <li><i class="fas fa-clock"></i> Code expires in 30 minutes</li>
                    <li><i class="fas fa-user-check"></i> One-time verification</li>
                </ul>
            </div>
        </div>
        <div class="auth-form-container">
            <div class="auth-form-wrapper">
                <div class="auth-header">
                    <h2>Verify Your Email</h2>
                    <p>Enter the 6-digit code we sent to your email</p>
                </div>
                @if (TempData["Error"] != null) { <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i><span>@TempData["Error"]</span></div> }
                @if (TempData["Success"] != null) { <div class="alert alert-success"><i class="fas fa-check-circle"></i><span>@TempData["Success"]</span></div> }
                <form asp-controller="Account" asp-action="ConfirmMail" method="post" class="auth-form" id="confirmEmailForm">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label asp-for="Email"><i class="fas fa-envelope"></i> Email Address</label>
                        <input type="email" asp-for="Email" class="form-control" placeholder="Enter your email" required autofocus />
                    </div>
                    <div class="form-group">
                        <label asp-for="ConfirmCode"><i class="fas fa-key"></i> 6-Digit Code</label>
                        <input type="text" asp-for="ConfirmCode" class="form-control text-center" maxlength="6" placeholder="000000" required pattern="[0-9]{6}" />
                    </div>
                    <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-check"></i> Confirm Email</button>
                </form>
                <div class="auth-footer">
                    <p>Back to <a asp-controller="Account" asp-action="Login" class="auth-link">Login</a></p>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/auth.js" asp-append-version="true"></script>
</body>
</html>
