@model PaymentSystem.Shared.Dtos.AuthDtos.ResetPasswordDto
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PaymentSystem</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="auth-body">
    <div class="auth-container">
        <div class="auth-branding">
            <div class="branding-content">
                <i class="fas fa-key"></i>
                <h1>Reset Password</h1>
                <p>Create a new secure password for your account</p>
                <ul class="features-list">
                    <li><i class="fas fa-lock"></i> Min 6 characters</li>
                    <li><i class="fas fa-check-double"></i> Passwords must match</li>
                    <li><i class="fas fa-shield-alt"></i> Use strong password</li>
                </ul>
            </div>
        </div>
        <div class="auth-form-container">
            <div class="auth-form-wrapper">
                <div class="auth-header">
                    <h2>Create New Password</h2>
                    <p>Enter your new password below</p>
                </div>
                @if (TempData["Error"] != null) { <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i><span>@TempData["Error"]</span></div> }
                @if (TempData["Success"] != null) { <div class="alert alert-success"><i class="fas fa-check-circle"></i><span>@TempData["Success"]</span></div> }
                <form asp-controller="Account" asp-action="ResetPassword" method="post" class="auth-form" id="resetPasswordForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="code" value="@ViewBag.Code" />
                    <div class="form-group">
                        <label asp-for="Email"><i class="fas fa-envelope"></i> Email Address</label>
                        <input type="email" asp-for="Email" class="form-control" placeholder="Enter your email" required autofocus />
                    </div>
                    <div class="form-group">
                        <label asp-for="NewPassword"><i class="fas fa-lock"></i> New Password</label>
                        <div class="password-input-wrapper">
                            <input type="password" asp-for="NewPassword" class="form-control" placeholder="Min 6 characters" required minlength="6" />
                            <button type="button" class="toggle-password" onclick="togglePassword('NewPassword')"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="ConfirmNewPassword"><i class="fas fa-lock"></i> Confirm New Password</label>
                        <div class="password-input-wrapper">
                            <input type="password" asp-for="ConfirmNewPassword" class="form-control" placeholder="Re-enter password" required minlength="6" />
                            <button type="button" class="toggle-password" onclick="togglePassword('ConfirmNewPassword')"><i class="fas fa-eye"></i></button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-check"></i> Reset Password</button>
                </form>
                <div class="auth-footer">
                    <p>Back to <a asp-controller="Account" asp-action="Login" class="auth-link">Login</a></p>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/auth.js" asp-append-version="true"></script>
</body>
</html>
