@model PaymentSystem.Shared.Dtos.AuthDtos.RegisterDto
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PaymentSystem</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="auth-body">
    <div class="auth-container">
        <div class="auth-branding">
            <div class="branding-content">
                <i class="fas fa-user-plus"></i>
                <h1>Create Account</h1>
                <p>Join our secure payment platform</p>
                <ul class="features-list">
                    <li><i class="fas fa-check"></i> Free Registration</li>
                    <li><i class="fas fa-shield-alt"></i> Secure & Encrypted</li>
                    <li><i class="fas fa-bolt"></i> Instant Setup</li>
                    <li><i class="fas fa-headset"></i> 24/7 Support</li>
                </ul>
            </div>
        </div>
        <div class="auth-form-container">
            <div class="auth-form-wrapper">
                <div class="auth-header">
                    <h2>Create Your Account</h2>
                    <p>Fill in your details to get started</p>
                </div>
                @if (TempData["Error"] != null) { <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i><span>@TempData["Error"]</span></div> }
                <form asp-controller="Account" asp-action="Register" method="post" class="auth-form" id="registerForm">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label asp-for="NameSurname"><i class="fas fa-user"></i> Full Name</label>
                        <input type="text" asp-for="NameSurname" class="form-control" placeholder="John Doe" required autofocus />
                    </div>
                    <div class="form-group">
                        <label asp-for="Email"><i class="fas fa-envelope"></i> Email Address</label>
                        <input type="email" asp-for="Email" class="form-control" placeholder="john@example.com" required />
                    </div>
                    <div class="form-group">
                        <label asp-for="PhoneNumber"><i class="fas fa-phone"></i> Phone Number (Optional)</label>
                        <input type="tel" asp-for="PhoneNumber" class="form-control" placeholder="+1 234 567 8900" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Title"><i class="fas fa-briefcase"></i> Title (Optional)</label>
                        <input type="text" asp-for="Title" class="form-control" placeholder="Software Engineer" />
                    </div>
                    <div class="form-group">
                        <label asp-for="Birthdate"><i class="fas fa-calendar"></i> Birthdate (Optional)</label>
                        <input type="date" asp-for="Birthdate" class="form-control" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Password"><i class="fas fa-lock"></i> Password</label>
                            <div class="password-input-wrapper">
                                <input type="password" asp-for="Password" class="form-control" placeholder="Min 6 characters" required minlength="6" />
                                <button type="button" class="toggle-password" onclick="togglePassword('Password')"><i class="fas fa-eye"></i></button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label asp-for="ConfirmPassword"><i class="fas fa-lock"></i> Confirm Password</label>
                            <div class="password-input-wrapper">
                                <input type="password" asp-for="ConfirmPassword" class="form-control" placeholder="Re-enter password" required minlength="6" />
                                <button type="button" class="toggle-password" onclick="togglePassword('ConfirmPassword')"><i class="fas fa-eye"></i></button>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="checkbox-label">
                            <input type="checkbox" name="AcceptTerms" value="true" required />
                            <span class="checkmark"></span>
                            I accept the <a href="#" class="auth-link">Terms of Service</a> and <a href="#" class="auth-link">Privacy Policy</a>
                        </label>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block"><i class="fas fa-user-plus"></i> Create Account</button>
                </form>
                <div class="auth-footer">
                    <p>Already have an account? <a asp-controller="Account" asp-action="Login" class="auth-link">Sign In</a></p>
                </div>
            </div>
        </div>
    </div>
    <script src="~/js/auth.js" asp-append-version="true"></script>
</body>
</html>
