@model dynamic
@{
    ViewData["Title"] = "Edit Transaction";
    Layout = "_Layout";
}
<div class="container py-4">
    <div class="page-header mb-4"><h1><i class="fas fa-edit"></i> Edit Transaction</h1><p>Update transaction details</p></div>
    <div class="row justify-content-center"><div class="col-md-6"><div class="card"><div class="card-body">
        <form asp-controller="UserHome" asp-action="UpdateTransaction" method="post">@Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model?.Id" />
            <div class="mb-3"><label class="form-label">Amount</label><input type="number" name="Amount" class="form-control" value="@Model?.Amount" step="0.01" required /></div>
            <div class="mb-3"><label class="form-label">Reference</label><input type="text" name="Reference" class="form-control" value="@Model?.Reference" /></div>
            <div class="mb-3"><label class="form-label">Wallet ID</label><input type="number" name="WalletId" class="form-control" value="@Model?.WalletId" required /></div>
            <div class="mb-3"><label class="form-label">Currency ID</label><input type="number" name="CurrencyId" class="form-control" value="@Model?.CurrencyId" required /></div>
            <div class="mb-3"><label class="form-label">Transaction Type ID</label><input type="number" name="TransactionTypeId" class="form-control" value="@Model?.TransactionTypeId" required /></div>
            <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update</button><a asp-controller="UserHome" asp-action="MyTransactions" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a></div>
        </form>
    </div></div></div></div>
</div>
