@model List<dynamic>
@{
    ViewData["Title"] = "My Payments";
    Layout = "_Layout";
    var signalRHubUrl = ViewBag.SignalRHubUrl as string;
}
<div class="container py-4">
    <div class="page-header mb-4 d-flex justify-content-between align-items-center">
        <div><h1><i class="fas fa-credit-card"></i> My Payments</h1><p>Track your payment history</p></div>
        <div><a asp-controller="UserHome" asp-action="CreatePayment" class="btn btn-primary"><i class="fas fa-plus"></i> New Payment</a></div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="empty-state text-center py-5"><i class="fas fa-credit-card fa-4x text-muted mb-3"></i><h4>No payments found</h4><p class="text-muted">You haven't made any payments yet.</p></div>
    }
    else
    {
        <!-- Bulk Actions Bar -->
        <div class="bulk-actions-bar card mb-3">
            <div class="card-body"><div class="d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2"><input type="checkbox" id="selectAllCheckbox" onclick="toggleSelectAll()" /> <label>Select All</label><span id="selectedCount" class="text-muted">0 selected</span></div>
                <div><button type="button" class="btn btn-danger btn-sm" id="bulkDeleteBtn" onclick="bulkDelete()" disabled><i class="fas fa-trash-alt"></i> Delete Selected</button></div>
            </div></div>
        </div>
        <form id="bulkDeleteForm" asp-controller="UserHome" asp-action="BulkDeletePayments" method="post" style="display:none;"></form>

        <div class="card"><div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light"><tr><th><input type="checkbox" id="headerCheckbox" onclick="toggleSelectAll()" /></th><th>#</th><th>Amount</th><th>Card</th><th>Merchant</th><th>Date</th><th>Actions</th></tr></thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var p in Model)
                        {
                            <tr data-payment-id="@p.Id">
                                <td><input type="checkbox" class="row-checkbox" data-id="@p.Id" onclick="updateSelectedCount()" /></td>
                                <td>@i</td><td><strong>$@p.Amount</strong></td><td><code>@p.MaskedCardNumber</code></td><td>@p.MerchantName</td><td>@p.CreatedDate?.ToString("dd MMM yyyy")</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-controller="UserHome" asp-action="EditPayment" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i></a>
                                        <form asp-controller="UserHome" asp-action="SoftDeletePayment" asp-route-id="@p.Id" method="post" class="d-inline"><button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete?')"><i class="fas fa-trash"></i></button></form>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        </div></div>
    }
</div>

@section Scripts {
    <script>
        function toggleSelectAll(){var v=document.getElementById('selectAllCheckbox').checked||document.getElementById('headerCheckbox').checked;document.getElementById('selectAllCheckbox').checked=v;document.getElementById('headerCheckbox').checked=v;document.querySelectorAll('.row-checkbox').forEach(c=>{c.checked=v;});updateSelectedCount();}
        function updateSelectedCount(){var s=Array.from(document.querySelectorAll('.row-checkbox')).filter(c=>c.checked).length;document.getElementById('selectedCount').textContent=s+' selected';document.getElementById('bulkDeleteBtn').disabled=s===0;}
        function bulkDelete(){var ids=Array.from(document.querySelectorAll('.row-checkbox:checked')).map(c=>c.dataset.id);if(ids.length===0){alert('No items selected');return;}if(!confirm('Delete '+ids.length+' payments?'))return;var f=document.getElementById('bulkDeleteForm');f.querySelectorAll('input[name="ids"]').forEach(i=>i.remove());ids.forEach(id=>{var i=document.createElement('input');i.type='hidden';i.name='ids';i.value=id;f.appendChild(i);});f.submit();}
        @if (!string.IsNullOrEmpty(signalRHubUrl)) {
            <text>
            const handler = new window.PaymentSignalRHandler("@signalRHubUrl", {
                onPaymentStatusChanged: function(paymentId, data) { const row = document.querySelector(`[data-payment-id="${paymentId}"]`); if (row) { row.classList.add('highlight-row'); setTimeout(() => row.classList.remove('highlight-row'), 2000); } },
                onPaymentUpdate: function(data) { showUserToast(data.message || 'Payment updated', 'info'); }
            });
            handler.initialize().catch(err => console.error('[PaymentHub] Failed:', err));
            </text>
        }
    </script>
}
