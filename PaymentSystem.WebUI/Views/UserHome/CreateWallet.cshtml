@model dynamic
@{
    ViewData["Title"] = "Create Wallet";
    Layout = "_Layout";
}
<div class="container py-4">
    <div class="page-header mb-4">
        <h1><i class="fas fa-plus-circle"></i> Create Wallet</h1>
        <p>Add a new wallet to your account</p>
    </div>
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <form asp-controller="UserHome" asp-action="CreateWallet" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3"><label class="form-label">Currency ID</label><input type="number" name="CurrencyId" class="form-control" placeholder="e.g., 1 (USD)" required /></div>
                        <div class="mb-3"><label class="form-label">Initial Balance</label><input type="number" name="Balance" class="form-control" value="0" step="0.01" required /></div>
                        <div class="d-flex gap-2"><button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create</button><a asp-controller="UserHome" asp-action="MyWallets" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
