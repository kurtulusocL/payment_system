@model dynamic
@{
    ViewData["Title"] = "Update Security Setting";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-edit"></i> Update Security Setting</h1><p>Edit security setting</p></div><a asp-controller="SecuritySetting" asp-action="GetAllSecuritySettings" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="SecuritySetting" asp-action="UpdateSecuritySetting" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="Id" value="@Model?.Id" />
        <div class="form-group"><label for="Type">Type</label><input type="text" id="Type" name="Type" class="form-control" value="@Model?.Type" required /></div>
        <div class="form-group"><label for="Value">Value</label><input type="text" id="Value" name="Value" class="form-control" value="@Model?.Value" required /></div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Update</button>
            <a asp-controller="SecuritySetting" asp-action="GetAllSecuritySettings" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div></div>
