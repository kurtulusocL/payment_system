@model dynamic
@{
    ViewData["Title"] = "Create Security Setting";
    Layout = "_AdminLayout";
}
<div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-plus-circle"></i> Create Security Setting</h1><p>Add a new security setting</p></div><a asp-controller="SecuritySetting" asp-action="GetAllSecuritySettings" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a></div></div>
<div class="card"><div class="card-body">
    <form asp-controller="SecuritySetting" asp-action="CreateSecuritySetting" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group"><label for="Type">Type</label><input type="text" id="Type" name="Type" class="form-control" placeholder="e.g., MaxLoginAttempts" required /></div>
        <div class="form-group"><label for="Value">Value</label><input type="text" id="Value" name="Value" class="form-control" placeholder="e.g., 5" required /></div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create</button>
            <a asp-controller="SecuritySetting" asp-action="GetAllSecuritySettings" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
        </div>
    </form>
</div></div>
