@model List<dynamic>
@{
    ViewData["Title"] = "Audit Logs by User";
    Layout = "_AdminLayout";
    var userId = ViewBag.UserId as string;
}

<div class="audit-by-user-page">
    <!-- Page Header -->
    <div class="page-header">
        <div class="flex-between">
            <div>
                <h1><i class="fas fa-user-shield"></i> Audit Logs by User</h1>
                <p>User ID: <code>@userId</code></p>
            </div>
            <div>
                <a asp-controller="Audit" asp-action="GetAllAudits" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to All Audits
                </a>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-list-alt"></i> User Audit Records</h3>
        </div>
        <div class="card-body">
            @if (Model == null || Model.Count == 0)
            {
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <p>No audit records found for this user</p>
                    <a asp-controller="Audit" asp-action="GetAllAudits" class="btn btn-primary mt-3">
                        <i class="fas fa-arrow-left"></i> Back to All Audits
                    </a>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-3">
                    <i class="fas fa-info-circle"></i>
                    <strong>@Model.Count</strong> audit record(s) found for this user
                </div>

                <div class="table-responsive">
                    <table class="data-table" id="audit-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Action</th>
                                <th>Area Accessed</th>
                                <th>IP Address</th>
                                <th>Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <thead>
                            <tr>
                                <th></th>
                                <th><input type="text" class="column-search" placeholder="Search action..." /></th>
                                <th><input type="text" class="column-search" placeholder="Search area..." /></th>
                                <th><input type="text" class="column-search" placeholder="Search IP..." /></th>
                                <th></th>
                                <th><select class="column-search">
                                    <option value="">All</option>
                                    <option value="Active">Active</option>
                                    <option value="Inactive">Inactive</option>
                                    <option value="Deleted">Deleted</option>
                                </select></th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int i = 1;
                            }
                            @foreach (var audit in Model)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td><span class="badge badge-info">@audit.Action</span></td>
                                    <td>@audit.AreaAccessed</td>
                                    <td><code>@audit.IpAddress</code></td>
                                    <td>@audit.CreatedDate?.ToString("dd MMM yyyy HH:mm")</td>
                                    <td>
                                        @if (audit.IsActive == true && audit.IsDeleted == false)
                                        {
                                            <span class="status-badge status-active">Active</span>
                                        }
                                        else if (audit.IsDeleted == true)
                                        {
                                            <span class="status-badge status-deleted">Deleted</span>
                                        }
                                        else
                                        {
                                            <span class="status-badge status-inactive">Inactive</span>
                                        }
                                    </td>
                                    <td class="actions-cell">
                                        <!-- View Details -->
                                        <a asp-controller="Audit" asp-action="GetAuditById" asp-route-id="@audit.Id" class="btn btn-sm btn-info" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#audit-table').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json"
                },
                "pageLength": 50,
                "lengthMenu": [[25, 50, 100, 250, -1], [25, 50, 100, 250, "All"]],
                "order": [[4, 'desc']],
                "columnDefs": [
                    { "orderable": false, "targets": [6] }
                ],
                "dom": '<"top"lf>rt<"bottom"ip><"clear">'
            });

            // Column filtering
            table.columns().every(function() {
                var that = this;
                var columnIndex = this.index();
                
                // Only apply filters to columns 1,2,3,5 (Action, Area, IP, Status)
                if ([1, 2, 3, 5].includes(columnIndex)) {
                    $('.column-search').eq(this.index()).on('keyup change', function() {
                        if (that.search() !== this.value) {
                            that.search(this.value, false, true).draw();
                        }
                    });
                }
            });

            console.log('User Audit DataTable with Column Filters Initialized');
        });
    </script>
}
