@model dynamic
@{
	ViewData["Title"] = "Create Payment Status";
	Layout = "_AdminLayout";
}

<div class="page-header">
	<div class="flex-between">
		<div><h1><i class="fas fa-plus-circle"></i> Create Payment Status</h1><p>Add a new payment status</p></div>
		<a asp-controller="PaymentStatus" asp-action="GetAllPaymentStatuses" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back</a>
	</div>
</div>
<div class="card">
	<div class="card-body">
		<form asp-controller="PaymentStatus" asp-action="CreatePaymentStatus" method="post">
			@Html.AntiForgeryToken()
			<div class="form-group"><label for="Name">Name</label><input type="text" id="Name" name="Name" class="form-control" placeholder="e.g., Pending" required /></div>
			<div class="form-actions">
				<button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Create</button>
				<a asp-controller="PaymentStatus" asp-action="GetAllPaymentStatuses" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
			</div>
		</form>
	</div>
</div>
