@model List<dynamic>
@{
    ViewData["Title"] = "Transaction Types By Transactions";
    Layout = "_AdminLayout";
}
<div class="transaction-type-list-page">
    <div class="page-header"><div class="flex-between"><div><h1><i class="fas fa-chart-bar"></i> Transaction Types By Transactions</h1><p>Transaction types ordered by transaction count</p></div><div><a asp-controller="TransactionType" asp-action="CreateTransactionType" class="btn btn-primary"><i class="fas fa-plus"></i> New Type</a></div></div></div>
    <div class="filter-links mb-3">
        <a asp-controller="TransactionType" asp-action="GetAllTransactionTypes" class="btn btn-outline-secondary"><i class="fas fa-list"></i> Active</a>
        <a asp-controller="TransactionType" asp-action="GetAllTransactionTypesByTransactions" class="btn btn-primary active-filter"><i class="fas fa-chart-bar"></i> By Transactions</a>
        <a asp-controller="TransactionType" asp-action="GetAllTransactionTypesForAdmin" class="btn btn-outline-secondary"><i class="fas fa-shield-alt"></i> All (Admin)</a>
    </div>
    <div class="card"><div class="card-body">
        @if (Model == null || Model.Count == 0) { <div class="empty-state"><i class="fas fa-inbox"></i><p>No transaction types found</p></div> }
        else {
            <div class="table-responsive">
                <table class="data-table" id="transaction-type-table">
                    <thead><tr><th>#</th><th>Name</th><th>Transaction Count</th><th>Status</th><th>Actions</th></tr></thead>
                    <thead><tr><th></th><th><input type="text" class="column-search" placeholder="Search name..." /></th><th></th><th><select class="column-search"><option value="">All</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></th><th></th></tr></thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var t in Model) {
                            <tr><td>@i</td><td><strong>@t.Name</strong></td><td>@t.TransactionCount</td><td>@(t.IsActive == true ? "<span class='status-badge status-active'>Active</span>" : "<span class='status-badge status-inactive'>Inactive</span>")</td>
                            <td class="actions-cell">
                                <a asp-controller="TransactionType" asp-action="GetTransactionTypeById" asp-route-id="@t.Id" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                                <a asp-controller="TransactionType" asp-action="GetTransactionTypeForEdit" asp-route-id="@t.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                                @if (t.IsActive == false) { <form asp-controller="TransactionType" asp-action="SetActive" asp-route-id="@t.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Set active?')"><i class="fas fa-check"></i></button></form> }
                                else { <form asp-controller="TransactionType" asp-action="SetInactive" asp-route-id="@t.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Set inactive?')"><i class="fas fa-ban"></i></button></form> }
                                @if (t.IsDeleted == false) { <form asp-controller="TransactionType" asp-action="SoftDelete" asp-route-id="@t.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Soft delete?')"><i class="fas fa-trash"></i></button></form> }
                                else { <form asp-controller="TransactionType" asp-action="Restore" asp-route-id="@t.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-primary" onclick="return confirm('Restore?')"><i class="fas fa-undo"></i></button></form> }
                            </td></tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div></div>
</div>
@section Scripts {
    <script>
        $(document).ready(function() {
            var t = $('#transaction-type-table').DataTable({"language": {"url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json"}, "pageLength": 50, "lengthMenu": [[25,50,100,250,-1],[25,50,100,250,"All"]], "order":[[2,'desc']], "columnDefs":[{"orderable":false,"targets":[4]}], "dom": '<"top"lf>rt<"bottom"ip><"clear">'});
            t.columns().every(function(){var th=this;if([1,3].includes(this.index())){$('.column-search').eq(this.index()).on('keyup change',function(){if(th.search()!==this.value){th.search(this.value,false,true).draw();}});}});
        });
    </script>
}
