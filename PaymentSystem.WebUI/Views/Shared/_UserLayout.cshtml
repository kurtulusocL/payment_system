<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PaymentSystem</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/user-layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body>
    <!-- User Navbar -->
    <nav class="user-navbar">
        <div class="user-navbar-container">
            <!-- Brand -->
            <a asp-controller="Home" asp-action="Index" class="navbar-brand">
                <i class="fas fa-university"></i>
                <span>PaymentSystem</span>
            </a>

            <!-- Navbar Toggle (Mobile) -->
            <button class="navbar-toggler" type="button" onclick="toggleUserMobileMenu()">
                <i class="fas fa-bars"></i>
            </button>

            <!-- Navbar Links -->
            <ul class="user-navbar-nav" id="userNavbar">
                <!-- Dashboard -->
                <li class="nav-item">
                    <a asp-controller="Home" asp-action="Index" class="nav-link">
                        <i class="fas fa-home"></i> Dashboard
                    </a>
                </li>

                <!-- Wallet -->
                <li class="nav-item">
                    @{
                        var userId = User?.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                    }
                    <a asp-controller="Wallet" asp-action="GetWalletsByUserId" asp-route-userId="@userId" class="nav-link">
                        <i class="fas fa-wallet"></i> My Wallet
                    </a>
                </li>

                <!-- Payments -->
                <li class="nav-item">
                    <a asp-controller="Payment" asp-action="GetPaymentsByUserId" asp-route-userId="@userId" class="nav-link">
                        <i class="fas fa-credit-card"></i> Payments
                    </a>
                </li>

                <!-- Transactions -->
                <li class="nav-item">
                    <a asp-controller="Transaction" asp-action="GetAllTransactions" class="nav-link">
                        <i class="fas fa-exchange-alt"></i> Transactions
                    </a>
                </li>

                <!-- Merchants -->
                <li class="nav-item">
                    <a asp-controller="Merchant" asp-action="GetAllMerchants" class="nav-link">
                        <i class="fas fa-store"></i> Merchants
                    </a>
                </li>
            </ul>

            <!-- User Profile Dropdown (Right side) -->
            <ul class="user-navbar-nav user-navbar-nav-right">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle user-profile-toggle" href="#" onclick="toggleUserDropdown(this)">
                        <i class="fas fa-user-circle"></i>
                        <span class="user-name">@User.Identity?.Name</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-right">
                        <li><a asp-controller="Account" asp-action="Profile" class="dropdown-item"><i class="fas fa-user-edit"></i> My Profile</a></li>
                        <li><a asp-controller="Account" asp-action="ChangePassword" class="dropdown-item"><i class="fas fa-key"></i> Change Password</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item-form">
                                <button type="submit" class="dropdown-item dropdown-item-logout">
                                    <i class="fas fa-sign-out-alt"></i> Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="user-main-content">
        <div class="container">
            <!-- Toast Container -->
            <div id="toast-container"></div>

            <!-- Alerts -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Error:</strong> @TempData["Error"]
                    <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
                </div>
            }
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i>
                    <strong>Success:</strong> @TempData["Success"]
                    <button type="button" class="btn-close" onclick="this.parentElement.remove()"></button>
                </div>
            }

            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="user-footer">
        <div class="container">
            <p>&copy; @DateTime.UtcNow.Year - PaymentSystem. All rights reserved.</p>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js" asp-fallback-src="~/lib/signalr/signalr.min.js" asp-fallback-test="window.signalR"></script>
    <script src="~/js/signalr-connection.js" asp-append-version="true"></script>
    <script src="~/js/user-layout.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
