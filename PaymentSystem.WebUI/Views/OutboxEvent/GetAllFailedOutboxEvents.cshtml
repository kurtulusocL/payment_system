@model List<dynamic>
@{
    ViewData["Title"] = "Failed Outbox Events";
    Layout = "_AdminLayout";
}
<div class="outbox-list-page">
    <div class="page-header"><div><h1><i class="fas fa-times-circle"></i> Failed Outbox Events</h1><p>Failed outbox events requiring attention</p></div></div>
    <div class="filter-links mb-3">
        <a asp-controller="OutboxEvent" asp-action="GetAllOutboxEvents" class="btn btn-outline-secondary"><i class="fas fa-list"></i> All</a>
        <a asp-controller="OutboxEvent" asp-action="GetAllSuccessfulOutboxEvents" class="btn btn-outline-secondary"><i class="fas fa-check"></i> Successful</a>
        <a asp-controller="OutboxEvent" asp-action="GetAllFailedOutboxEvents" class="btn btn-primary active-filter"><i class="fas fa-times"></i> Failed</a>
        <a asp-controller="OutboxEvent" asp-action="GetAllOutboxEventsForAdmin" class="btn btn-outline-secondary"><i class="fas fa-shield-alt"></i> All (Admin)</a>
    </div>
    <div class="card"><div class="card-body">
        @if (Model == null || Model.Count == 0) { <div class="empty-state"><i class="fas fa-inbox"></i><p>No failed outbox events found</p></div> }
        else {
            <div class="table-responsive">
                <table class="data-table" id="outbox-table">
                    <thead><tr><th>#</th><th>Entity Type</th><th>Event Type</th><th>Is Processed</th><th>Date</th><th>Status</th><th>Actions</th></tr></thead>
                    <thead><tr><th></th><th><input type="text" class="column-search" placeholder="Search entity..." /></th><th><input type="text" class="column-search" placeholder="Search event..." /></th><th></th><th></th><th><select class="column-search"><option value="">All</option><option value="Active">Active</option><option value="Inactive">Inactive</option></select></th><th></th></tr></thead>
                    <tbody>
                        @{ int i = 1; }
                        @foreach (var ev in Model) {
                            <tr><td>@i</td><td><code>@ev.EntityType</code></td><td>@ev.EventType</td><td><span class="status-badge status-deleted">No</span></td><td>@ev.CreatedDate?.ToString("dd MMM yyyy HH:mm")</td><td>@(ev.IsActive == true ? "<span class='status-badge status-active'>Active</span>" : "<span class='status-badge status-inactive'>Inactive</span>")</td>
                            <td class="actions-cell">
                                <a asp-controller="OutboxEvent" asp-action="GetOutboxEventById" asp-route-id="@ev.Id" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                                @if (ev.IsActive == false) { <form asp-controller="OutboxEvent" asp-action="SetActive" asp-route-id="@ev.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Set active?')"><i class="fas fa-check"></i></button></form> }
                                else { <form asp-controller="OutboxEvent" asp-action="SetInactive" asp-route-id="@ev.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Set inactive?')"><i class="fas fa-ban"></i></button></form> }
                                @if (ev.IsDeleted == false) { <form asp-controller="OutboxEvent" asp-action="SoftDelete" asp-route-id="@ev.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Soft delete?')"><i class="fas fa-trash"></i></button></form> }
                                else { <form asp-controller="OutboxEvent" asp-action="Restore" asp-route-id="@ev.Id" method="post" class="inline-form"><button type="submit" class="btn btn-sm btn-primary" onclick="return confirm('Restore?')"><i class="fas fa-undo"></i></button></form> }
                            </td></tr>
                            i++;
                        }
                    </tbody>
                </table>
            </div>
        }
    </div></div>
</div>
@section Scripts {
    <script>
        $(document).ready(function() {
            var t = $('#outbox-table').DataTable({"language": {"url": "//cdn.datatables.net/plug-ins/1.13.7/i18n/en-GB.json"}, "pageLength": 50, "lengthMenu": [[25,50,100,250,-1],[25,50,100,250,"All"]], "order":[[4,'desc']], "columnDefs":[{"orderable":false,"targets":[6]}], "dom": '<"top"lf>rt<"bottom"ip><"clear">'});
            t.columns().every(function(){var th=this;if([1,2,5].includes(this.index())){$('.column-search').eq(this.index()).on('keyup change',function(){if(th.search()!==this.value){th.search(this.value,false,true).draw();}});}});
        });
    </script>
}
