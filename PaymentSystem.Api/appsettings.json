{
    "ConnectionStrings": {
        "DefaultConnection": "your_connection_strings",
        "AzureConnection": "your_azure_connection_strings",
        "AzureStorageConnection": "UseDevelopmentStorage=true",
        "Redis": "your_localhost",
        "RabbitMQ": "your_rabbitMQ_configuration"
    },
    "JwtSettings": {
        "Secret": "your-super-secret-key-min-32-characters-long",
        "Issuer": "PaymentSystem",
        "Audience": "PaymentSystemClient",
        "ExpiryMinutes": 60
    },
    "Encryption": {
        "Key": "your key"
    },
    "MailSettings": {
        "Server": "smtp.gmail.com",
        "Port": 587,
        "SenderName": "Payment_System",
        "SenderEmail": "your_mail_address",
        "Password": "mail_massword",
        "DisplayName": "PaymentSystem"
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }
        }
    },
    "RateLimit": {
        "Web": {
            "PermitLimit": 100,
            "WindowSeconds": 60
        },
        "SignalR": {
            "PermitLimit": 200,
            "WindowSeconds": 60
        }
    },
    "ApiKey": "your-merchant-api-key-here",
    "RabbitMQ": {
        "ExchangeName": "paymentsystem.exchange",
        "PaymentQueueName": "paymentsystem.payment.queue",
        "NotificationQueueName": "paymentsystem.notification.queue"
    },
    "AllowedHosts": "*"
}
